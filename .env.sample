# cal-cli configuration

# Auth: requires OUTLOOK_REFRESH_TOKEN + OUTLOOK_TENANT_ID
#
# If OUTLOOK_APP_CLIENT_ID is set, uses that app registration directly
# (standard OAuth2 refresh_token grant - more durable).
# Otherwise falls back to owa-piggy (no app registration needed).

# MSAL refresh token - extract from browser localStorage:
#   const key = Object.keys(localStorage).find(k => k.includes('|refreshtoken|'))
#   JSON.parse(localStorage.getItem(key)).secret
OUTLOOK_REFRESH_TOKEN=""

# Azure AD tenant ID
#   const key = Object.keys(localStorage).find(k => k.includes('|idtoken|'))
#   JSON.parse(localStorage.getItem(key)).realm
OUTLOOK_TENANT_ID=""

# App registration client ID (optional - omit to use owa-piggy instead)
# Requires a registered Azure AD app with Calendars.ReadWrite delegated permission
OUTLOOK_APP_CLIENT_ID=""

# Display
default_timezone="W. Europe Standard Time"
debug=0
